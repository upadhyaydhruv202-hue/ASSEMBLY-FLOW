{
  "name": "assemblyflow-erp-backend",
  "version": "1.0.0",
  "description": "AssemblyFlow ERP - Manufacturing, Storage & Door Tracking API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset && node prisma/seed-reference.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "bwip-js": "^4.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "pdfkit": "^0.17.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
